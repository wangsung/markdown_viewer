{
  "manifest_version": 3,
  "name": "로컬 마크다운 뷰어 (Offline MD Viewer)",
  "version": "1.0.0",
  "description": "로컬 마크다운 파일(.md)을 브라우저에서 열었을 때 자동으로 아름답게 프리뷰해 줍니다.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "file:///*/*.md",
        "file:///*/*.markdown"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "markdown_viewer.html",
        "style.css",
        "app.js",
        "libs/*",
        "libs/codemirror/*",
        "libs/codemirror/mode/markdown/*",
        "libs/codemirror/mode/xml/*",
        "libs/katex/*",
        "libs/katex/fonts/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
